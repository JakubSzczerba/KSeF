{% extends 'base.html.twig' %}

{% block title %}KSeF UI{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --r: 18px;
            --shadow: 0 16px 40px rgba(7, 14, 35, 0.2);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Manrope", sans-serif;
            transition: background 200ms ease, color 200ms ease;
        }

        body[data-theme="light"] {
            color: #132235;
            background:
                radial-gradient(1000px 420px at 10% 0%, rgba(255, 162, 80, 0.2), transparent 62%),
                radial-gradient(850px 440px at 95% 5%, rgba(107, 192, 255, 0.23), transparent 64%),
                linear-gradient(170deg, #f4f8ff, #eff6ff);
        }

        body[data-theme="dark"] {
            color: #dbe7f9;
            background:
                radial-gradient(1000px 460px at 8% 0%, rgba(255, 130, 60, 0.22), transparent 58%),
                radial-gradient(900px 460px at 95% 8%, rgba(81, 166, 255, 0.24), transparent 65%),
                linear-gradient(175deg, #0b1021, #0f1a31);
        }

        #ksef-react-root { min-height: 100vh; }
    </style>
{% endblock %}

{% block body %}
    <div
        id="ksef-react-root"
        data-bootstrap="{{ bootstrap|json_encode|e('html_attr') }}"
    ></div>
{% endblock %}

{% block javascripts %}
    <script type="module" src="/ui/react-dashboard.js"></script>
{% endblock %}
